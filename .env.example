# ── remove.bg API ──────────────────────────────────────────────────────────────
# Free tier: 50 calls/month  →  https://www.remove.bg/api
# Without this key, the app uses client-side background removal (less accurate)
REMOVE_BG_API_KEY=your_removebg_api_key_here

# ── Anthropic API (Claude Vision face detection) ────────────────────────────────
# Used for accurate AI face detection  →  https://console.anthropic.com
# Without this key, the app falls back to face-api.js (CDN) then center-crop
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── App URL (used for SEO / sitemap) ───────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://euidphoto.com
